    </div><!-- /.admin-content -->
  </div><!-- /.admin-main -->
</div><!-- /.admin-wrapper -->

<script>
  // Sidebar mobile toggle
  const sidebarToggle = document.getElementById('sidebarToggle');
  const adminSidebar  = document.getElementById('adminSidebar');
  const adminMain     = document.getElementById('adminMain');
  if (sidebarToggle) {
    sidebarToggle.addEventListener('click', () => {
      adminSidebar.classList.toggle('open');
    });
    // Close sidebar when clicking outside on mobile
    adminMain.addEventListener('click', () => {
      if (adminSidebar.classList.contains('open')) {
        adminSidebar.classList.remove('open');
      }
    });
  }

  // Image upload preview (used on create/edit event forms)
  function previewImage(input, previewId) {
    const preview  = document.getElementById(previewId);
    const nameSpan = input.parentElement.querySelector('.file-input-name');
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = e => {
        preview.src = e.target.result;
        preview.style.display = 'block';
      };
      reader.readAsDataURL(input.files[0]);
      if (nameSpan) nameSpan.textContent = input.files[0].name;
      // If user picks a new image, clear the remove-image flag
      const removeFlag = document.getElementById('removeImageField');
      if (removeFlag) removeFlag.value = '0';
    }
  }
</script>

</body>
</html>
