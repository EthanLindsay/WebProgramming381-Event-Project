<%- include('../partials/header') %>

<%
  const now        = new Date();
  const confirmed  = bookings.filter(b => b.status === 'confirmed');
  const upcoming   = confirmed.filter(b => b.event && new Date(b.event.date) >= now);
  const totalSpent = confirmed.reduce((sum, b) => sum + b.totalPrice, 0);
  // "past" = everything that isn't an upcoming confirmed booking
  const pastAll    = bookings.filter(b => {
    const isFutureConfirmed = b.status === 'confirmed' && b.event && new Date(b.event.date) >= now;
    return !isFutureConfirmed;
  });
%>

<!-- ── Hero ───────────────────────────────────────────────────── -->
<div class="user-dashboard-hero">
  <div class="container user-dashboard-hero-inner">
    <div class="user-avatar-lg"><%= user.name.charAt(0).toUpperCase() %></div>
    <div>
      <h1>Welcome back, <%= user.name.split(' ')[0] %>!</h1>
      <p>Manage your bookings and discover what's on next.</p>
    </div>
    <a href="/events" class="btn btn-primary" style="margin-left:auto;">Browse Events</a>
  </div>
</div>

<!-- ── Main content ───────────────────────────────────────────── -->
<div class="dashboard-page">
  <div class="container">

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <!-- Stat cards -->
    <div class="dashboard-stats-row">
      <div class="dashboard-stat-card accent-purple">
        <div class="dashboard-stat-number"><%= upcoming.length %></div>
        <div class="dashboard-stat-label">Upcoming Events</div>
      </div>
      <div class="dashboard-stat-card accent-green">
        <div class="dashboard-stat-number"><%= confirmed.length %></div>
        <div class="dashboard-stat-label">Confirmed Bookings</div>
      </div>
      <div class="dashboard-stat-card accent-navy">
        <div class="dashboard-stat-number">R&nbsp;<%= totalSpent.toFixed(2) %></div>
        <div class="dashboard-stat-label">Total Spent</div>
      </div>
    </div>

    <% if (bookings.length === 0) { %>

      <!-- Empty state -->
      <div class="empty-state">
        <div class="empty-state-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
               width="30" height="30" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v2z"/>
            <line x1="9" y1="2" x2="9" y2="22"/>
          </svg>
        </div>
        <h3>No bookings yet</h3>
        <p>You haven't booked any events. Discover what's on and grab your tickets!</p>
        <a href="/events" class="btn btn-primary">Browse Events</a>
      </div>

    <% } else { %>

      <!-- ── Upcoming bookings ─────────────────────────────────── -->
      <% if (upcoming.length > 0) { %>
        <div class="bookings-section-title">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               width="18" height="18" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8"  y1="2" x2="8"  y2="6"/>
            <line x1="3"  y1="10" x2="21" y2="10"/>
          </svg>
          Upcoming Events
          <span class="admin-count-badge"><%= upcoming.length %></span>
        </div>

        <div class="bookings-list" style="margin-bottom:40px;">
          <% upcoming.forEach(booking => { %>
            <div class="booking-card-new">

              <!-- Image -->
              <div class="booking-card-img">
                <% if (booking.event && booking.event.image) { %>
                  <img src="<%= booking.event.image %>" alt="<%= booking.event.title %>" />
                <% } %>
              </div>

              <!-- Details -->
              <div class="booking-card-body">
                <div class="booking-card-title">
                  <% if (booking.event) { %>
                    <a href="/events/<%= booking.event._id %>"><%= booking.event.title %></a>
                  <% } else { %>Event no longer available<% } %>
                </div>

                <% if (booking.event) { %>
                  <div class="booking-card-meta">
                    <span class="booking-card-meta-item">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                           width="12" height="12">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8"  y1="2" x2="8"  y2="6"/>
                        <line x1="3"  y1="10" x2="21" y2="10"/>
                      </svg>
                      <%= new Date(booking.event.date).toLocaleDateString('en-ZA',{weekday:'short',day:'numeric',month:'short',year:'numeric'}) %>
                    </span>
                    <span class="booking-card-meta-item">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                           width="12" height="12">
                        <circle cx="12" cy="12" r="10"/>
                        <polyline points="12 6 12 12 16 14"/>
                      </svg>
                      <%= booking.event.time %>
                    </span>
                    <span class="booking-card-meta-item">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                           width="12" height="12">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                      </svg>
                      <%= booking.event.location %>
                    </span>
                  </div>
                <% } %>

                <div class="booking-card-footer">
                  <span class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
                  <% if (booking.status === 'confirmed') { %>
                    <form action="/bookings/<%= booking._id %>/cancel" method="POST"
                          onsubmit="return confirm('Are you sure you want to cancel this booking? This cannot be undone.')">
                      <button type="submit" class="btn btn-danger btn-sm">Cancel Booking</button>
                    </form>
                  <% } %>
                </div>
              </div>

              <!-- Price panel -->
              <div class="booking-card-right">
                <div class="booking-card-price <%= booking.totalPrice === 0 ? 'free' : '' %>">
                  <% if (booking.totalPrice === 0) { %>Free<% } else { %>R&nbsp;<%= booking.totalPrice.toFixed(2) %><% } %>
                </div>
                <div class="booking-card-tickets">
                  <%= booking.ticketCount %> ticket<%= booking.ticketCount !== 1 ? 's' : '' %>
                </div>
              </div>

            </div>
          <% }) %>
        </div>
      <% } %>

      <!-- ── Past & cancelled bookings ────────────────────────── -->
      <% if (pastAll.length > 0) { %>
        <div class="bookings-section-title" style="color:var(--text-muted); border-bottom-color:var(--border);">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               width="18" height="18" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          Past &amp; Cancelled
          <span class="admin-count-badge"><%= pastAll.length %></span>
        </div>

        <div class="bookings-list" style="opacity:0.72;">
          <% pastAll.forEach(booking => { %>
            <div class="booking-card-new past-card <%= booking.status === 'cancelled' ? 'cancelled-card' : '' %>">

              <!-- Image -->
              <div class="booking-card-img">
                <% if (booking.event && booking.event.image) { %>
                  <img src="<%= booking.event.image %>" alt="<%= booking.event.title %>" />
                <% } %>
              </div>

              <!-- Details -->
              <div class="booking-card-body">
                <div class="booking-card-title">
                  <% if (booking.event) { %><%= booking.event.title %>
                  <% } else { %>Event no longer available<% } %>
                </div>

                <% if (booking.event) { %>
                  <div class="booking-card-meta">
                    <span class="booking-card-meta-item">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                           width="12" height="12">
                        <rect x="3" y="4" width="18" height="18" rx="2"/>
                        <line x1="16" y1="2" x2="16" y2="6"/>
                        <line x1="8"  y1="2" x2="8"  y2="6"/>
                        <line x1="3"  y1="10" x2="21" y2="10"/>
                      </svg>
                      <%= new Date(booking.event.date).toLocaleDateString('en-ZA',{weekday:'short',day:'numeric',month:'short',year:'numeric'}) %>
                    </span>
                    <span class="booking-card-meta-item">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                           width="12" height="12">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                      </svg>
                      <%= booking.event.location %>
                    </span>
                  </div>
                <% } %>

                <div class="booking-card-footer">
                  <span class="status-badge status-<%= booking.status %>"><%= booking.status %></span>
                </div>
              </div>

              <!-- Price panel -->
              <div class="booking-card-right">
                <div class="booking-card-price" style="color:var(--text-muted); font-size:1.125rem;">
                  <% if (booking.totalPrice === 0) { %>Free<% } else { %>R&nbsp;<%= booking.totalPrice.toFixed(2) %><% } %>
                </div>
                <div class="booking-card-tickets">
                  <%= booking.ticketCount %> ticket<%= booking.ticketCount !== 1 ? 's' : '' %>
                </div>
              </div>

            </div>
          <% }) %>
        </div>
      <% } %>

    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
