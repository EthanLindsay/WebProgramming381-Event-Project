<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | EventHub Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="admin-body">

<div class="admin-wrapper">

  <!-- ── SIDEBAR ─────────────────────────────────────────────── -->
  <aside class="admin-sidebar" id="adminSidebar">

    <div class="admin-sidebar-header">
      <a href="/admin/dashboard" class="admin-logo">Event<span>Hub</span></a>
      <span class="admin-role-badge">Admin</span>
    </div>

    <div class="admin-user-card">
      <div class="admin-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
      <div class="admin-user-info">
        <div class="admin-user-name"><%= user.name %></div>
        <div class="admin-user-role">Administrator</div>
      </div>
    </div>

    <nav class="admin-nav">
      <span class="admin-nav-label">Overview</span>

      <a href="/admin/dashboard" class="admin-nav-item <%= currentPath === '/admin/dashboard' ? 'active' : '' %>">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        Dashboard
      </a>

      <span class="admin-nav-label">Manage</span>

      <a href="/admin/events" class="admin-nav-item <%= currentPath.startsWith('/admin/events') ? 'active' : '' %>">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Events
      </a>

      <a href="/admin/enquiries" class="admin-nav-item <%= currentPath === '/admin/enquiries' ? 'active' : '' %>">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Enquiries
      </a>

      <span class="admin-nav-label">Site</span>

      <a href="/events" class="admin-nav-item" target="_blank">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        View Live Site
      </a>

      <a href="/auth/logout" class="admin-nav-item admin-nav-logout">
        <svg class="admin-nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
          <polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
        </svg>
        Logout
      </a>
    </nav>

  </aside>

  <!-- ── MAIN AREA ────────────────────────────────────────────── -->
  <div class="admin-main" id="adminMain">

    <!-- Top bar -->
    <header class="admin-topbar">
      <button class="admin-sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
        <span></span><span></span><span></span>
      </button>
      <h1 class="admin-topbar-title"><%= title %></h1>
      <div class="admin-topbar-right">
        <a href="/events" target="_blank" class="btn btn-outline btn-sm">View Site</a>
      </div>
    </header>

    <!-- Page content -->
    <div class="admin-content">
