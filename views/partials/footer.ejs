</main>

<footer class="footer">
  <div class="container footer-inner">
    <div>
      <div class="footer-brand">Event<span>Hub</span></div>
      <div class="footer-copy">&copy; <%= new Date().getFullYear() %> Advanced Events (Pty) Ltd. All rights reserved.</div>
    </div>
    <div class="footer-links">
      <a href="/events">Events</a>
      <a href="/contact">Contact</a>
      <% if (user) { %>
        <% if (user.role !== 'admin') { %>
          <a href="/bookings/dashboard">My Bookings</a>
        <% } %>
        <a href="/auth/logout">Logout</a>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
      <% } %>
    </div>
  </div>
</footer>

<script>
  // ── Mobile nav toggle with animated hamburger ──────────────────
  const navToggle = document.getElementById('navToggle');
  const navLinks  = document.getElementById('navLinks');
  if (navToggle) {
    navToggle.addEventListener('click', () => {
      const isOpen = navLinks.classList.toggle('open');
      navToggle.classList.toggle('open', isOpen);
      navToggle.setAttribute('aria-expanded', isOpen);
    });
    // Close when clicking outside
    document.addEventListener('click', e => {
      if (!navToggle.contains(e.target) && !navLinks.contains(e.target)) {
        navLinks.classList.remove('open');
        navToggle.classList.remove('open');
        navToggle.setAttribute('aria-expanded', 'false');
      }
    });
  }

  // ── Image upload preview (used on admin forms) ─────────────────
  function previewImage(input, previewId) {
    const preview  = document.getElementById(previewId);
    const nameSpan = input.parentElement.querySelector('.file-input-name');
    if (input.files && input.files[0]) {
      const reader = new FileReader();
      reader.onload = e => {
        preview.src = e.target.result;
        preview.style.display = 'block';
      };
      reader.readAsDataURL(input.files[0]);
      if (nameSpan) nameSpan.textContent = input.files[0].name;
    }
  }
</script>

</body>
</html>
