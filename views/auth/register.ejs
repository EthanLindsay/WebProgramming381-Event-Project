<%- include('../partials/header') %>

<div class="form-page">
  <div class="form-card">

    <h1 class="form-title">Create account</h1>
    <p class="form-subtitle">Join EventHub to start booking events</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form action="/auth/register" method="POST" novalidate>

      <div class="form-group">
        <label for="name" class="form-label">Full name</label>
        <input
          type="text" id="name" name="name"
          class="form-input" required autocomplete="name"
          placeholder="Jane Smith"
        />
      </div>

      <div class="form-group">
        <label for="email" class="form-label">Email address</label>
        <input
          type="email" id="email" name="email"
          class="form-input" required autocomplete="email"
          placeholder="you@example.com"
        />
      </div>

      <div class="form-group">
        <label for="password" class="form-label">Password</label>
        <input
          type="password" id="password" name="password"
          class="form-input" required autocomplete="new-password"
          placeholder="At least 8 characters"
        />
      </div>

      <div class="form-group">
        <label for="confirmPassword" class="form-label">Confirm password</label>
        <input
          type="password" id="confirmPassword" name="confirmPassword"
          class="form-input" required autocomplete="new-password"
          placeholder="Repeat your password"
        />
      </div>

      <button type="submit" class="btn btn-primary btn-full btn-lg">Create Account</button>
    </form>

    <p class="form-footer">
      Already have an account? <a href="/auth/login" class="form-link">Sign in</a>
    </p>

  </div>
</div>

<%- include('../partials/footer') %>
